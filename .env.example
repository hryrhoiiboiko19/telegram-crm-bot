# ===== Telegram Bot =====
# Get your bot token from @BotFather
BOT_TOKEN=

# ===== PostgreSQL =====
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=crm_db
# When running with docker-compose, use "postgresql://postgres:PASSWORD@postgres:5432/crm_db"
# When running locally, use "postgresql://postgres:PASSWORD@localhost:5432/crm_db"
DATABASE_URL=

# ===== Redis =====
# When running with docker-compose, use "redis"
# When running locally, use "localhost"
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== Google Sheets Integration =====
# Apps Script Web App URL that receives POST with order data
GOOGLE_SHEETS_WEBHOOK_URL=

# ===== Admin Access =====
# Comma-separated Telegram user IDs who get admin access
# Find your ID via @userinfobot
ADMIN_IDS=